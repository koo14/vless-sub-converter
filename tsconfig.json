{
  "compilerOptions": {
    "target": "es2021",
    "module": "Node16",
    "lib": ["es2021", "DOM"],
    "moduleResolution": "node16",
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"]
}
